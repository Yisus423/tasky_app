<TaskCard>:
    orientation: 'horizontal'
    size_hint_y: None
    height: '50dp'
    spacing: '10dp'
    padding: '5dp'

    Label:
        text: root.task_text
        text_size: self.size
        halign: 'left'
        valign: 'middle'

    Button:
        text: 'X'
        size_hint_x: None
        width: '40dp'
        background_color: 0.8, 0.2, 0.2, 1
        on_press: root.delete_action()
