<MenuScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: '40dp'
        spacing: '20dp'
        
        Label:
            text: "Bienvenido a Tasky App"
            font_size: '32sp'
            bold: True
            
        Button:
            text: "Ir a mis Tareas"
            font_size: '20sp'
            size_hint_y: None
            height: '60dp'
            background_color: 0.2, 0.8, 0.2, 1
            on_press:
                root.manager.transition.direction = 'left'
                root.manager.current = 'tasks'
